# Copy this file to .env locally and fill in the values you want to use.
# Do not commit .env.

# Required for default OpenAI LLM and embeddings.
OPEN_API_KEY=

# Optional Gemini provider.
GEMINI_API_KEY=

# Provider choices: openai or gemini
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Model choices
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# RAG tuning. These are character counts, roughly 500-1000 tokens per chunk.
CHROMA_COLLECTION_NAME=autodesk_html_pages
STREAMLIT_HOST_PORT=8502
CHUNK_SIZE=3500
CHUNK_OVERLAP=500
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BATCH_DELAY_SECONDS=1.0
EMBEDDING_MAX_RETRIES=8
MIN_RELEVANCE_SCORE=0.30
HYBRID_CANDIDATE_K=30
HYBRID_VECTOR_WEIGHT=0.65
HYBRID_BM25_WEIGHT=0.35
HYBRID_MAX_PER_SOURCE=3
MIN_RELEVANCE_SCORE=0.30
RETRIEVER_K=10

# Deterministic context expansion after retrieval and before evidence gating/generation.
CONTEXT_EXPANSION_ENABLED=true
CONTEXT_EXPANSION_MODE=neighbors
CONTEXT_NEIGHBOR_WINDOW=1
CONTEXT_MAX_EXPANDED_DOCS=8
CONTEXT_MAX_CHARS=18000

# Cross-encoder reranking before the adequacy gate.
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
RERANKER_TOP_N=5
RERANKER_BATCH_SIZE=16

# Option 3/4 local BM25 hybrid retrieval.
BM25_INDEX_FILE=docling_bm25_chunks.json

# Docling PDF parsing. Use cuda locally when a CUDA-enabled PyTorch install is available.
DOCLING_ACCELERATOR_DEVICE=auto
DOCLING_NUM_THREADS=4
DOCLING_DO_OCR=false
DOCLING_BATCH_SIZE=1
DOCLING_MAX_PAGES=250
DOCLING_PAGE_CHUNK_SIZE=30
DOCLING_PAGE_OVERLAP=5

# Required for Settings & Eval LangSmith evaluation. Tracing can be disabled if desired.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=autodesk-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
EVAL_JUDGE_MODEL=gpt-5.1
EVAL_JUDGE_DELAY_SECONDS=1.0
EVAL_JUDGE_MAX_RETRIES=8

# Optional placeholder for hosted Chroma setups. Local Chroma does not require it.
CHROMA_API_KEY=

# Required for Google web fallback through SerpAPI.
SERPAPI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=